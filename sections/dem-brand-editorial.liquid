<style>
  .dem-editorial {
    padding: 100px 2rem;
    text-align: center;
    background: rgb(var(--dem-bg));
    color: rgb(var(--dem-black));
  }

  .dem-editorial--dark {
    background: rgb(var(--dem-black));
    color: rgb(var(--dem-white));
  }

  .dem-editorial__inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .dem-editorial__heading {
    font-family: var(--dem-font-serif);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 200;
    letter-spacing: 0.01em;
    line-height: 1.06;
    margin: 0 0 1.5rem;
    color: inherit;
  }

  .dem-editorial__subtext {
    font-family: var(--dem-font-sans);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 2.5rem;
    color: rgb(var(--dem-muted));
  }

  .dem-editorial--dark .dem-editorial__subtext {
    color: rgba(255, 255, 255, 0.6);
  }

  @media screen and (max-width: 749px) {
    .dem-editorial { padding: 72px 1.5rem; }
  }
</style>

<section
  class="dem-editorial{% if section.settings.bg_dark %} dem-editorial--dark{% endif %}"
  id="section-{{ section.id }}"
>
  <div class="dem-editorial__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="dem-editorial__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="dem-editorial__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link | default: '/collections/all' }}"
        class="dem-btn{% if section.settings.bg_dark %} dem-btn--light{% endif %}"
      >
        {{- section.settings.button_label -}}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Dem Editorial",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Bestsellers, Crafted for Modern Elegance"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Each piece in our collection is selected for quality of material, precision of cut, and longevity of wear. No filler. No fast fashion."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "bg_dark",
      "label": "Dark background",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Dem Editorial"
    }
  ]
}
{% endschema %}
