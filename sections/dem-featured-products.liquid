<style>
  .dem-products {
    padding: 80px 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .dem-products__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .dem-products__heading {
    font-family: var(--dem-font-serif);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 200;
    letter-spacing: 0.01em;
    margin: 0 0 0.75rem;
    color: rgb(var(--dem-black));
  }

  .dem-products__subheading {
    font-family: var(--dem-font-sans);
    font-size: 0.9rem;
    color: rgb(var(--dem-muted));
    margin: 0;
    letter-spacing: 0.03em;
  }

  .dem-products__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px 24px;
  }

  .dem-product-card {
    display: block;
    text-decoration: none;
    color: rgb(var(--dem-black));
  }

  .dem-product-card__image-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: rgb(var(--dem-border));
    margin-bottom: 1rem;
  }

  .dem-product-card__image-wrap img,
  .dem-product-card__image-wrap svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .dem-product-card:hover .dem-product-card__image-wrap img {
    transform: scale(1.03);
  }

  .dem-product-card__title {
    font-family: var(--dem-font-sans);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: center;
    margin: 0;
  }

  .dem-products__footer {
    text-align: center;
    margin-top: 3.5rem;
  }

  @media screen and (max-width: 989px) {
    .dem-products__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px 16px;
    }
  }

  @media screen and (max-width: 479px) {
    .dem-products {
      padding: 60px 1.2rem;
    }
    .dem-products__grid {
      gap: 24px 12px;
    }
  }
</style>

{%- liquid
  assign the_collection = collections[section.settings.collection]
  assign product_limit   = section.settings.products_to_show | default: 4
-%}

<section class="dem-products" id="section-{{ section.id }}">
  <div class="dem-products__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="dem-products__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="dem-products__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="dem-products__grid">
    {%- if the_collection != blank and the_collection.products_count > 0 -%}
      {%- for product in the_collection.products limit: product_limit -%}
        <a href="{{ product.url }}" class="dem-product-card">
          <div class="dem-product-card__image-wrap">
            {%- if product.featured_image -%}
              {{
                product.featured_image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  widths: '300, 500, 700, 800',
                  sizes: '(max-width: 749px) 50vw, 25vw',
                  alt: product.featured_image.alt | default: product.title
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <p class="dem-product-card__title">{{ product.title }}</p>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..product_limit) -%}
        <div class="dem-product-card">
          <div class="dem-product-card__image-wrap">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
          <p class="dem-product-card__title">Sample Product {{ i }}</p>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if section.settings.button_label != blank -%}
    <div class="dem-products__footer">
      <a
        href="{{ section.settings.button_link | default: '/collections/all' }}"
        class="dem-btn dem-btn--ghost"
      >
        {{- section.settings.button_label -}}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Dem Products",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Crafted for modern elegance"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "View all button label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "Dem Products"
    }
  ]
}
{% endschema %}
