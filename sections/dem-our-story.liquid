<style>
  .dem-our-story {
    padding: 0 2rem 120px;
    background: #ffffff;
    text-align: center;
  }

  .dem-our-story__inner {
    max-width: 900px !important;
    margin: 0 auto;
  }

  .dem-our-story__heading {
    font-family: var(--dem-font-serif, 'Newsreader', Georgia, serif);
    font-size: 5rem !important;
    font-weight: 200;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: #000000 !important;
    margin-top: 150px !important;
    margin-bottom: 2.5rem;
  }

  .dem-our-story__rule {
    width: 48px;
    height: 1px;
    background: #000000;
    margin: 0 auto 3rem;
  }

  .dem-our-story__body {
    font-family: var(--dem-font-sans, 'Red Hat Text', sans-serif);
    font-size: 1.25rem !important;
    line-height: 1.6 !important;
    color: #666666;
    margin: 0 auto;
    max-width: 900px !important;
    white-space: normal !important;
  }

  @media screen and (max-width: 749px) {
    .dem-our-story { padding: 0 1.5rem 80px; }
    .dem-our-story__heading {
      font-size: 2.8rem !important;
      margin-top: 100px !important;
    }
    .dem-our-story__body { font-size: 1.1rem !important; }
  }
</style>

<section class="dem-our-story" id="section-{{ section.id }}">
  <div class="dem-our-story__inner">
    <h1 class="dem-our-story__heading">{{ section.settings.heading }}</h1>
    <div class="dem-our-story__rule"></div>
    <p class="dem-our-story__body">{{ section.settings.body }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Dem Our Story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Pursuit of Honest Luxury"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "The inception of Demetti began with a shared observation of a broken system. We were disillusioned by an industry where price tags were untethered from reality\u2014often reaching a ten times markup. We are a team of three who believe a garment\u2019s essence lies in its architecture. By dismantling traditional retail overhead and working directly with premier mills, we offer uncompromising quality at an honest price. This is smart luxury, reimagined."
    }
  ],
  "presets": [
    {
      "name": "Dem Our Story"
    }
  ]
}
{% endschema %}
