<style>
  .dem-page-hero {
    padding: 80px 2rem 64px;
    text-align: center;
    background: rgb(var(--dem-bg));
    border-bottom: 1px solid rgb(var(--dem-border));
  }

  .dem-page-hero__eyebrow {
    font-family: var(--dem-font-sans);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgb(var(--dem-muted));
    margin: 0 0 1.5rem;
  }

  .dem-page-hero__heading {
    font-family: var(--dem-font-serif);
    font-size: clamp(4rem, 8vw, 7rem);
    font-weight: 200;
    letter-spacing: 0.01em;
    line-height: 1;
    margin: 0 0 1.5rem;
    color: rgb(var(--dem-black));
  }

  .dem-page-hero__rule {
    width: 48px;
    height: 1px;
    background: rgb(var(--dem-black));
    margin: 0 auto 1.5rem;
  }

  .dem-page-hero__subheading {
    font-family: var(--dem-font-sans);
    font-size: 0.95rem;
    color: rgb(var(--dem-muted));
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.65;
  }

  @media screen and (max-width: 749px) {
    .dem-page-hero { padding: 56px 1.5rem 48px; }
  }
</style>

<div class="dem-page-hero" id="section-{{ section.id }}">
  {%- if section.settings.eyebrow != blank -%}
    <p class="dem-page-hero__eyebrow">{{ section.settings.eyebrow }}</p>
  {%- endif -%}

  <h1 class="dem-page-hero__heading">{{ section.settings.heading }}</h1>
  <div class="dem-page-hero__rule"></div>

  {%- if section.settings.subheading != blank -%}
    <p class="dem-page-hero__subheading">{{ section.settings.subheading }}</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Dem Page Hero",
  "tag": "div",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Demetti"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore the Demetti range \u2014 precision cut, built to endure."
    }
  ],
  "presets": [
    {
      "name": "Dem Page Hero"
    }
  ]
}
{% endschema %}
